SELECT * FROM students;

SELECT AVG(marks) AS average_marks
FROM students;

SELECT branch, AVG(marks) AS avg_marks
FROM students
GROUP BY branch;

SELECT branch, AVG(marks) AS avg_marks
FROM students
GROUP BY branch
HAVING AVG(marks) > 80;

SELECT branch, COUNT(*) AS total_students
FROM students
GROUP BY branch;

SELECT branch, MAX(marks) AS highest_marks
FROM students
GROUP BY branch;
