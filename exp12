<div class="container">

    <h2>PHP Array Example</h2>

    <?php
    // Indexed Array
    $colors = array("Red", "Blue", "Green", "Yellow");

    echo "<div class='box'>";
    echo "<h3>Indexed Array Elements</h3>";

    foreach($colors as $color) {
        echo "<p>$color</p>";
    }

    echo "</div>";

    // Associative Array
    $student = array(
        "Name" => "Rahul",
        "Age" => 20,
        "Course" => "BCA"
    );

    echo "<div class='box'>";
    echo "<h3>Associative Array Elements</h3>";

    foreach($student as $key => $value) {
        echo "<p><b>$key :</b> $value</p>";
    }

    echo "</div>";
    ?>

</div>

</body>
</html>
