-- Create Database
CREATE DATABASE college;
USE college;

-- Create Table
CREATE TABLE Employee (
    id INT PRIMARY KEY,
    name VARCHAR(50),
    salary INT
);

-- Create Trigger
DELIMITER //

CREATE TRIGGER check_salary
BEFORE INSERT ON Employee
FOR EACH ROW
BEGIN
    IF NEW.salary < 0 THEN
        SET NEW.salary = 0;
    END IF;
END //

DELIMITER ;

-- Insert Data
INSERT INTO Employee VALUES (1, 'Pratik', 5000);
INSERT INTO Employee VALUES (2, 'Rahul', -2000);

-- Display Table
SELECT * FROM Employee;
