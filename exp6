<body>
    <form name="My form" action="exp6.html" onsubmit="return validateForm()" method="post">
        <label>Email id</label>
        <input type="email" id="u_email" placeholder="Enter email">
        <br>
        <label>Password</label>
        <input type="password" id="u_password" placeholder="*******">
        <br>
        <button type="submit" id="login">login</button>
    </form>

    <script>
        function validateForm(){
            var email = document.getElementById("u_email").value.trim();
            var password = document.getElementById("u_password").value.trim();
             if (email==='' || password ===''){
                alert("email or pass can not be empty");
                return false;
             }

             alert('validation successful');
             return true;
        }
    </script>
