-- Create database
CREATE DATABASE company_db;
USE company_db;

-- Create employee table
CREATE TABLE emp (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(20),
    salary INT
);

-- Insert sample data
INSERT INTO emp(name, salary) VALUES
('Rahul', 50000),
('Amit', 45000),
('Sneha', 60000),
('Priya', 55000);

-- Change delimiter
DELIMITER $$

-- Create procedure
CREATE PROCEDURE show_names()
BEGIN

    DECLARE e_name VARCHAR(20);
    DECLARE done INT DEFAULT 0;

    -- Declare cursor
    DECLARE cur CURSOR FOR
        SELECT name FROM emp;

    -- Declare handler
    DECLARE CONTINUE HANDLER FOR NOT FOUND
        SET done = 1;

    -- Open cursor
    OPEN cur;

    -- Loop through rows
    read_loop: LOOP

        FETCH cur INTO e_name;

        IF done = 1 THEN
            LEAVE read_loop;
        END IF;

        -- Display employee name
        SELECT e_name AS Employee_Name;

    END LOOP;

    -- Close cursor
    CLOSE cur;

END $$

-- Reset delimiter
DELIMITER ;

-- Call procedure
CALL show_names();
