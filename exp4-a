<!DOCTYPE html>
<html>
<head>
    <title>CSS Example</title>

    <!-- Internal CSS -->
    <style>
        h2 {
            color: blue;
            text-align: center;
        }

        table {
            width: 60%;
            border-collapse: collapse;
            margin: auto;
        }

        th, td {
            border: 1px solid black;
            padding: 10px;
            text-align: center;
        }

        th {
            background-color: lightgray;
        }
    </style>

    <!-- External CSS -->
    <link rel="stylesheet" href="style.css">

</head>

<body>

    <!-- Inline CSS -->
    <h1 style="color:red; text-align:center;">
        Welcome to CSS Styling
    </h1>

    <h2>Student Details Table</h2>

    <table>
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Course</th>
        </tr>

        <tr>
            <td>Rahul</td>
            <td>19</td>
            <td>Computer Engineering</td>
        </tr>

        <tr>
            <td>Aman</td>
            <td>20</td>
            <td>Information Technology</td>
        </tr>
    </table>

</body>
</html>
